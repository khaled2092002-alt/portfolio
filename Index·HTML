<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Khaled Ahmed | مسوّق رقمي وصانع محتوى</title>
<meta name="description" content="خالد أحمد - مسوّق رقمي وصانع محتوى. إدارة حملات السوشيال ميديا، كتابة وإخراج وتصوير الفيديو، وتصميم الهويات البصرية.">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@400;500;700;800;900&family=Almarai:wght@300;400;700;800&display=swap" rel="stylesheet">
<style>
  :root{
    --bg:#080b13;
    --bg-soft:#0f1420;
    --bg-card:rgba(255,255,255,0.035);
    --text:#eef1f7;
    --text-muted:#8891a8;
    --accent:#22d3ee;
    --accent-soft:#67e8f9;
    --gold:#a78bfa;
    --line:rgba(238,241,247,0.10);
    --radius:18px;
  }
  *{margin:0;padding:0;box-sizing:border-box;}
  html{scroll-behavior:smooth;}
  body{
    background:var(--bg);
    color:var(--text);
    font-family:'Almarai',sans-serif;
    line-height:1.7;
    overflow-x:hidden;
  }
  h1,h2,h3,h4,.display{font-family:'Tajawal',sans-serif;}
  a{color:inherit;text-decoration:none;}
  ul{list-style:none;}
  img{max-width:100%;display:block;}
  section{padding:110px 8vw;position:relative;}
  .eyebrow{
    display:inline-flex;align-items:center;gap:10px;
    font-size:13px;letter-spacing:3px;text-transform:uppercase;
    color:var(--accent-soft);font-weight:700;margin-bottom:18px;
  }
  .eyebrow::before{content:"";width:26px;height:2px;background:var(--accent);display:inline-block;}
  .section-title{font-size:clamp(28px,4vw,42px);font-weight:800;margin-bottom:14px;}
  .section-sub{color:var(--text-muted);max-width:640px;margin-bottom:56px;font-size:16px;}
  .reveal{opacity:0;transform:translateY(34px);transition:opacity .8s cubic-bezier(.2,.7,.2,1),transform .8s cubic-bezier(.2,.7,.2,1);}
  .reveal.in{opacity:1;transform:translateY(0);}
  .reveal-delay-1{transition-delay:.08s;}
  .reveal-delay-2{transition-delay:.16s;}
  .reveal-delay-3{transition-delay:.24s;}
  .reveal-delay-4{transition-delay:.32s;}

  /* ---------- NAV ---------- */
  header{
    position:fixed;top:0;insetInlineStart:0;width:100%;z-index:100;
    display:flex;align-items:center;justify-content:space-between;
    padding:20px 8vw;backdrop-filter:blur(14px);
    background:rgba(21,21,28,0.65);
    border-bottom:1px solid var(--line);
    transition:padding .3s ease;
  }
  .logo{font-weight:900;font-size:20px;letter-spacing:.5px;}
  .logo span{color:var(--accent);}
  nav ul{display:flex;gap:34px;}
  nav a{font-size:14px;font-weight:700;color:var(--text-muted);position:relative;padding:4px 0;transition:color .25s;}
  nav a:hover{color:var(--text);}
  nav a::after{content:"";position:absolute;bottom:-2px;insetInlineStart:0;width:0;height:2px;background:var(--accent);transition:width .3s;}
  nav a:hover::after{width:100%;}
  .nav-toggle{display:none;flex-direction:column;gap:5px;cursor:pointer;background:none;border:none;}
  .nav-toggle span{width:26px;height:2px;background:var(--text);}

  /* ---------- HERO ---------- */
  .hero{
    min-height:100vh;display:flex;flex-direction:column;justify-content:center;
    padding-top:160px;padding-bottom:60px;
    position:relative;overflow:hidden;
  }
  .blob{position:absolute;filter:blur(80px);opacity:.4;z-index:0;animation:float 14s ease-in-out infinite, morph 10s ease-in-out infinite;mix-blend-mode:screen;}
  .blob-1{width:440px;height:440px;background:radial-gradient(circle at 35% 30%,var(--accent-soft),var(--accent) 45%,transparent 75%);top:-130px;inset-inline-end:-110px;}
  .blob-2{width:360px;height:360px;background:radial-gradient(circle at 35% 30%,#c4b5fd,var(--gold) 45%,transparent 75%);bottom:-110px;inset-inline-start:-90px;animation-delay:-6s,-3s;}
  @keyframes float{
    0%,100%{transform:translate(0,0) scale(1);}
    50%{transform:translate(30px,-40px) scale(1.08);}
  }
  @keyframes morph{
    0%,100%{border-radius:42% 58% 65% 35% / 45% 40% 60% 55%;}
    33%{border-radius:65% 35% 40% 60% / 55% 65% 35% 45%;}
    66%{border-radius:35% 65% 55% 45% / 40% 55% 45% 60%;}
  }
  .sphere{
    position:absolute;border-radius:50%;z-index:0;pointer-events:none;
    background:radial-gradient(circle at 32% 28%, rgba(255,255,255,.9), rgba(103,232,249,.5) 30%, rgba(167,139,250,.35) 60%, rgba(8,11,19,0) 78%);
    box-shadow:0 0 40px rgba(103,232,249,.35), inset 0 0 30px rgba(255,255,255,.15);
    animation:sphere-float 9s ease-in-out infinite;
  }
  .sphere-1{width:34px;height:34px;top:18%;inset-inline-start:6%;animation-delay:0s;}
  .sphere-2{width:20px;height:20px;top:62%;inset-inline-start:14%;animation-delay:-3s;}
  .sphere-3{width:26px;height:26px;top:32%;inset-inline-end:10%;animation-delay:-5.5s;}
  @keyframes sphere-float{
    0%,100%{transform:translateY(0) translateX(0);}
    50%{transform:translateY(-26px) translateX(10px);}
  }
  .hero-grid{display:grid;grid-template-columns:1.15fr 0.85fr;gap:60px;align-items:center;position:relative;z-index:1;}
  .hero h1{font-size:clamp(38px,5.4vw,64px);font-weight:900;line-height:1.08;margin:14px 0 6px;}
  .hero h1 .hl{color:var(--accent);}
  .hero .role{font-size:clamp(18px,2vw,24px);color:var(--gold);font-weight:700;margin-bottom:22px;}
  .hero p{color:var(--text-muted);max-width:560px;font-size:17px;margin-bottom:34px;}
  .cta-row{display:flex;gap:16px;flex-wrap:wrap;margin-bottom:40px;}
  .btn{
    display:inline-flex;align-items:center;gap:8px;
    padding:15px 30px;border-radius:100px;font-weight:700;font-size:15px;
    transition:transform .25s ease, box-shadow .25s ease;
  }
  .btn-primary{background:var(--accent);color:#191119;box-shadow:0 10px 30px -8px rgba(255,92,114,.6);}
  .btn-primary:hover{transform:translateY(-3px);box-shadow:0 16px 34px -6px rgba(255,92,114,.7);}
  .btn-ghost{border:1px solid var(--line);color:var(--text);}
  .btn-ghost:hover{border-color:var(--accent);color:var(--accent-soft);transform:translateY(-3px);}

  .social-row{display:flex;gap:14px;flex-wrap:wrap;}
  .social-pill{
    width:46px;height:46px;border-radius:50%;
    display:flex;align-items:center;justify-content:center;
    border:1px solid var(--line);color:var(--text-muted);
    transition:all .25s ease;
  }
  .social-pill svg{width:19px;height:19px;}
  .social-pill:hover{border-color:var(--accent);color:var(--accent-soft);transform:translateY(-4px);background:rgba(255,92,114,.08);}

  /* hero visual: rotating card stack (signature element) */
  .hero-visual{position:relative;height:420px;display:flex;align-items:center;justify-content:center;}
  .avatar-ring{
    position:relative;width:230px;height:230px;border-radius:50%;
    padding:6px;
    background:linear-gradient(140deg,var(--accent),var(--gold));
    display:flex;align-items:center;justify-content:center;
    box-shadow:0 0 0 1px rgba(255,255,255,.08), 0 30px 70px -20px rgba(34,211,238,.5), 0 0 60px -10px rgba(167,139,250,.4);
  }
  .avatar-ring::before{
    content:"";position:absolute;inset:-14px;border-radius:50%;
    border:1.5px dashed rgba(238,241,247,.25);
    animation:spin-rev 26s linear infinite;
  }
  .avatar-ring img{width:100%;height:100%;border-radius:50%;object-fit:cover;display:block;}
  @keyframes spin-slow{from{transform:rotate(0deg)}to{transform:rotate(360deg)}}
  @keyframes spin-rev{from{transform:rotate(0deg)}to{transform:rotate(-360deg)}}

  .float-card{
    position:absolute;background:var(--bg-card);border:1px solid var(--line);
    border-radius:14px;padding:12px 16px;font-size:13px;font-weight:700;
    display:flex;align-items:center;gap:8px;box-shadow:0 20px 40px -18px rgba(0,0,0,.6);
    animation:bob 6s ease-in-out infinite;
  }
  .float-card i{width:8px;height:8px;border-radius:50%;background:var(--accent);display:inline-block;}
  .fc-1{top:10px;insetInlineStart:0;animation-delay:0s;}
  .fc-2{bottom:36px;insetInlineEnd:-10px;animation-delay:-2s;}
  .fc-3{bottom:0;insetInlineStart:20px;animation-delay:-4s;}
  @keyframes bob{0%,100%{transform:translateY(0)}50%{transform:translateY(-14px)}}

  /* filmstrip ticker - signature motif referencing video production */
  .filmstrip{
    position:relative;width:100%;overflow:hidden;
    border-top:1px solid var(--line);border-bottom:1px solid var(--line);
    background:var(--bg-soft);padding:16px 0;margin-top:20px;
  }
  .filmstrip::before,.filmstrip::after{
    content:"";position:absolute;top:0;bottom:0;width:60px;z-index:2;
  }
  .filmstrip::before{insetInlineStart:0;background:linear-gradient(90deg,var(--bg-soft),transparent);}
  .filmstrip::after{insetInlineEnd:0;background:linear-gradient(270deg,var(--bg-soft),transparent);}
  .ticker-track{display:flex;gap:0;width:max-content;animation:ticker 26s linear infinite;}
  .ticker-track span{
    padding:0 34px;font-size:14px;font-weight:800;letter-spacing:1px;color:var(--text-muted);
    border-inline-end:1px solid var(--line);white-space:nowrap;
  }
  .ticker-track span b{color:var(--gold);}
  @keyframes ticker{from{transform:translateX(0)}to{transform:translateX(-50%)}}

  /* ---------- STATS ---------- */
  .stats-row{display:grid;grid-template-columns:repeat(3,1fr);gap:24px;max-width:640px;}
  .stat-box{
    background:var(--bg-card);border:1px solid var(--line);border-radius:var(--radius);
    padding:26px 20px;text-align:center;transition:transform .3s ease,border-color .3s ease;
  }
  .stat-box:hover{transform:translateY(-6px);border-color:var(--accent);}
  .stat-num{font-family:'Tajawal',sans-serif;font-weight:900;font-size:32px;color:var(--accent-soft);}
  .stat-label{color:var(--text-muted);font-size:13px;margin-top:6px;}

  /* ---------- ABOUT ---------- */
  .about-grid{display:grid;grid-template-columns:0.9fr 1.1fr;gap:70px;align-items:start;}
  .about-grid blockquote{
    margin-top:30px;padding:22px 24px;border-inline-start:3px solid var(--accent);
    background:var(--bg-soft);border-radius:0 12px 12px 0;color:var(--text-muted);font-style:normal;font-size:15px;
  }
  .about-photo{
    position:relative;border-radius:var(--radius);overflow:hidden;aspect-ratio:4/5;
    background:linear-gradient(160deg,var(--bg-card),var(--bg-soft));
    border:1px solid var(--line);display:flex;align-items:center;justify-content:center;flex-direction:column;gap:14px;
  }
  .about-photo .big-initials{
    font-family:'Tajawal',sans-serif;font-weight:900;font-size:110px;
    background:linear-gradient(140deg,var(--accent),var(--gold));
    -webkit-background-clip:text;background-clip:text;color:transparent;
  }
  .about-photo small{color:var(--text-muted);font-size:12px;letter-spacing:1px;}
  .location-chip{
    position:absolute;bottom:18px;insetInlineStart:18px;display:flex;align-items:center;gap:8px;
    background:rgba(21,21,28,.75);backdrop-filter:blur(6px);padding:9px 16px;border-radius:100px;
    font-size:13px;font-weight:700;border:1px solid var(--line);
  }

  /* ---------- EXPERIENCE ---------- */
  .timeline{position:relative;padding-inline-start:36px;}
  .timeline::before{content:"";position:absolute;insetInlineStart:6px;top:6px;bottom:6px;width:2px;background:var(--line);}
  .tl-item{position:relative;padding-bottom:50px;}
  .tl-item:last-child{padding-bottom:0;}
  .tl-item::before{
    content:"";position:absolute;insetInlineStart:-36px;top:4px;width:14px;height:14px;border-radius:50%;
    background:var(--bg);border:3px solid var(--accent);
  }
  .tl-card{
    background:var(--bg-card);border:1px solid var(--line);border-radius:var(--radius);
    padding:28px 30px;transition:transform .3s ease,border-color .3s ease;
  }
  .tl-card:hover{transform:translateY(-4px);border-color:var(--accent);}
  .tl-card h3{font-size:20px;font-weight:800;margin-bottom:4px;}
  .tl-role{color:var(--gold);font-weight:700;font-size:14px;margin-bottom:14px;}
  .tl-card p{color:var(--text-muted);font-size:15px;margin-bottom:16px;}
  .tl-card strong{color:var(--text);}
  .tl-links{display:flex;gap:14px;flex-wrap:wrap;}
  .tl-links a{font-size:13px;font-weight:700;color:var(--accent-soft);border-bottom:1px solid transparent;}
  .tl-links a:hover{border-color:var(--accent-soft);}

  /* ---------- SKILLS ---------- */
  .skills-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:22px;}
  .skill-card{
    background:var(--bg-card);border:1px solid var(--line);border-radius:var(--radius);
    padding:30px 26px;transition:transform .3s ease,border-color .3s ease,background .3s ease;position:relative;overflow:hidden;
  }
  .skill-card::before{
    content:"";position:absolute;inset:0;background:radial-gradient(circle at 30% 20%,rgba(255,92,114,.15),transparent 60%);
    opacity:0;transition:opacity .3s ease;
  }
  .skill-card:hover{transform:translateY(-6px);border-color:var(--accent);}
  .skill-card:hover::before{opacity:1;}
  .skill-icon{
    width:50px;height:50px;border-radius:14px;background:rgba(255,92,114,.12);
    display:flex;align-items:center;justify-content:center;margin-bottom:18px;color:var(--accent-soft);
  }
  .skill-card h4{font-size:17px;font-weight:800;margin-bottom:8px;}
  .skill-card p{color:var(--text-muted);font-size:14px;}

  /* ---------- PORTFOLIO ---------- */
  .portfolio-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:22px;}
  .p-card{
    position:relative;border-radius:var(--radius);overflow:hidden;aspect-ratio:4/5;
    border:1px solid var(--line);
  }
  .p-card .p-bg{
    position:absolute;inset:0;
    display:flex;align-items:center;justify-content:center;text-align:center;padding:20px;
    font-family:'Tajawal',sans-serif;font-weight:800;font-size:15px;color:rgba(242,239,233,.5);
    transition:transform .6s cubic-bezier(.2,.8,.2,1);
  }
  .p-card:nth-child(1) .p-bg{background:linear-gradient(150deg,#3a2420,#20202b);}
  .p-card:nth-child(2) .p-bg{background:linear-gradient(150deg,#233042,#20202b);}
  .p-card:nth-child(3) .p-bg{background:linear-gradient(150deg,#2c2036,#20202b);}
  .p-card:nth-child(4) .p-bg{background:linear-gradient(150deg,#233626,#20202b);}
  .p-card:nth-child(5) .p-bg{background:linear-gradient(150deg,#3a2e20,#20202b);}
  .p-card:hover .p-bg{transform:scale(1.08);}
  .p-overlay{
    position:absolute;inset:0;background:linear-gradient(0deg,rgba(21,21,28,.94),rgba(21,21,28,.1) 60%);
    display:flex;flex-direction:column;justify-content:flex-end;padding:22px;
    opacity:0;transition:opacity .35s ease;
  }
  .p-card:hover .p-overlay{opacity:1;}
  .p-overlay h4{font-size:16px;font-weight:800;margin-bottom:4px;}
  .p-overlay span{color:var(--text-muted);font-size:13px;}
  .p-overlay .view{margin-top:12px;font-size:13px;font-weight:700;color:var(--accent-soft);}

  /* ---------- VIDEO ---------- */
  .video-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:22px;}
  .v-card{
    background:var(--bg-card);border:1px solid var(--line);border-radius:var(--radius);overflow:hidden;
    transition:transform .3s ease,border-color .3s ease;
  }
  .v-card:hover{transform:translateY(-6px);border-color:var(--accent);}
  .v-thumb{
    aspect-ratio:16/10;background:linear-gradient(150deg,var(--bg-soft),#26262f);
    display:flex;align-items:center;justify-content:center;position:relative;
  }
  .play-btn{
    width:56px;height:56px;border-radius:50%;background:var(--accent);
    display:flex;align-items:center;justify-content:center;color:#191119;
    transition:transform .3s ease;
  }
  .v-card:hover .play-btn{transform:scale(1.12);}
  .v-body{padding:20px 22px;}
  .v-body h4{font-size:15px;font-weight:800;margin-bottom:4px;}
  .v-body p{color:var(--text-muted);font-size:13px;}

  /* ---------- CERTIFICATES ---------- */
  .cert-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:22px;}
  .cert-card{
    display:flex;align-items:center;gap:20px;
    background:var(--bg-card);border:1px solid var(--line);border-radius:var(--radius);
    padding:26px;transition:transform .3s ease,border-color .3s ease;
  }
  .cert-card:hover{transform:translateY(-4px);border-color:var(--gold);}
  .cert-icon{
    width:54px;height:54px;flex:none;border-radius:14px;background:rgba(255,207,92,.14);
    display:flex;align-items:center;justify-content:center;color:var(--gold);
  }
  .cert-card h4{font-size:16px;font-weight:800;margin-bottom:4px;}
  .cert-card p{color:var(--text-muted);font-size:13px;margin-bottom:8px;}
  .cert-card a{font-size:13px;font-weight:700;color:var(--accent-soft);}

  /* ---------- CONTACT ---------- */
  .contact-grid{display:grid;grid-template-columns:0.85fr 1.15fr;gap:60px;}
  .info-list{display:flex;flex-direction:column;gap:18px;margin-top:30px;}
  .info-item{
    display:flex;align-items:center;gap:16px;background:var(--bg-card);border:1px solid var(--line);
    border-radius:14px;padding:16px 20px;transition:border-color .3s ease,transform .3s ease;
  }
  .info-item:hover{border-color:var(--accent);transform:translateX(-4px);}
  html[dir="rtl"] .info-item:hover{transform:translateX(4px);}
  .info-icon{
    width:42px;height:42px;flex:none;border-radius:50%;background:rgba(255,92,114,.14);
    display:flex;align-items:center;justify-content:center;color:var(--accent-soft);
  }
  .info-item .lbl{font-size:12px;color:var(--text-muted);}
  .info-item .val{font-weight:700;font-size:14px;direction:ltr;text-align:right;unicode-bidi:plaintext;}

  form{background:var(--bg-card);border:1px solid var(--line);border-radius:var(--radius);padding:36px;}
  .form-row{display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:16px;}
  .field{display:flex;flex-direction:column;gap:8px;}
  .field label{font-size:13px;color:var(--text-muted);font-weight:700;}
  .field input,.field textarea{
    background:var(--bg-soft);border:1px solid var(--line);border-radius:10px;color:var(--text);
    padding:13px 16px;font-family:inherit;font-size:14px;transition:border-color .25s ease;
  }
  .field input:focus,.field textarea:focus{outline:none;border-color:var(--accent);}
  .field.full{grid-column:1/-1;}
  textarea{resize:vertical;min-height:120px;}
  .submit-btn{
    width:100%;margin-top:6px;background:var(--accent);color:#191119;border:none;
    padding:16px;border-radius:12px;font-weight:800;font-size:15px;cursor:pointer;
    transition:transform .25s ease,box-shadow .25s ease;font-family:inherit;
  }
  .submit-btn:hover{transform:translateY(-3px);box-shadow:0 16px 34px -6px rgba(255,92,114,.5);}
  .form-note{font-size:12px;color:var(--text-muted);margin-top:12px;text-align:center;}

  footer{
    padding:44px 8vw;border-top:1px solid var(--line);
    display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:20px;color:var(--text-muted);font-size:13px;
  }

  @media(max-width:980px){
    .hero-grid,.about-grid,.contact-grid{grid-template-columns:1fr;}
    .hero-visual{order:-1;height:300px;}
    .skills-grid,.portfolio-grid,.video-grid{grid-template-columns:repeat(2,1fr);}
    .cert-grid{grid-template-columns:1fr;}
    nav ul{display:none;}
    .nav-toggle{display:flex;}
  }
  @media(max-width:640px){
    section{padding:80px 6vw;}
    .skills-grid,.portfolio-grid,.video-grid{grid-template-columns:1fr;}
    .form-row{grid-template-columns:1fr;}
    .stats-row{grid-template-columns:1fr 1fr 1fr;gap:12px;}
  }
  @media (prefers-reduced-motion: reduce){
    *{animation:none !important;transition:none !important;}
  }

  /* glass surfaces — fluid glass / holographic feel */
  .skill-card,.tl-card,.cert-card,.stat-box,.v-card,form,.info-item,.float-card,.about-photo{
    backdrop-filter:blur(22px);-webkit-backdrop-filter:blur(22px);
    background:var(--bg-card);
    box-shadow:0 1px 0 rgba(255,255,255,.06) inset, 0 20px 40px -30px rgba(0,0,0,.7);
  }
  .skill-card:hover,.tl-card:hover,.cert-card:hover,.stat-box:hover,.v-card:hover{
    box-shadow:0 1px 0 rgba(255,255,255,.08) inset, 0 24px 50px -20px rgba(34,211,238,.25);
  }
</style>
</head>
<body>

<header>
  <div class="logo">Khaled <span>Ahmed</span></div>
  <nav>
    <ul>
      <li><a href="#about">عنّي</a></li>
      <li><a href="#experience">الخبرات</a></li>
