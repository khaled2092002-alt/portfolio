    --ink-2:#1a1730;
    --ink-3:#241f3f;
    --paper:#f7f2e8;
    --paper-dim:#ece4d3;
    --accent:#ff4d2e;
    --accent-2:#f0a63f;
    --violet:#9b7bff;
    --line:rgba(247,242,232,0.14);
    --line-dark:rgba(16,14,28,0.12);
    --text-soft:rgba(247,242,232,0.68);
    --ff-display:'Cairo', sans-serif;
    --ff-body:'Tajawal', sans-serif;
  }
  *{box-sizing:border-box; margin:0; padding:0;}
  html{scroll-behavior:smooth;}
  body{
    background:var(--ink);
    color:var(--paper);
    font-family:var(--ff-body);
    line-height:1.7;
    overflow-x:hidden;
    -webkit-font-smoothing:antialiased;
  }
  img{max-width:100%; display:block;}
  a{color:inherit; text-decoration:none;}
  ul{list-style:none;}
  .ltr{direction:ltr; unicode-bidi:isolate;}
  .wrap{max-width:1240px; margin:0 auto; padding:0 28px;}
  .eyebrow{
    font-family:var(--ff-body); font-weight:700; letter-spacing:.18em;
    text-transform:uppercase; font-size:12px; color:var(--accent-2);
    display:flex; align-items:center; gap:10px; margin-bottom:18px;
  }
  .eyebrow::before{content:""; width:26px; height:2px; background:var(--accent); display:inline-block;}
  h1,h2,h3{font-family:var(--ff-display); font-weight:800; line-height:1.15;}
  .section{padding:110px 0;}
  .section-title{font-size:clamp(30px,4.2vw,52px); margin-bottom:20px;}
  .section-sub{color:var(--text-soft); font-size:17px; max-width:640px;}

  /* ===== viewfinder corner-bracket signature element ===== */
  .viewfinder{position:relative; overflow:hidden; border-radius:6px; isolation:isolate;}
  .vf-corner{position:absolute; width:26px; height:26px; z-index:3; pointer-events:none;
    transition:transform .7s cubic-bezier(.16,.9,.2,1), opacity .5s ease;}
  .vf-corner::before,.vf-corner::after{content:""; position:absolute; background:var(--accent);}
  .vf-corner.tl{top:14px; left:14px; transform:translate(-10px,-10px);}
  .vf-corner.tr{top:14px; right:14px; transform:translate(10px,-10px);}
  .vf-corner.bl{bottom:14px; left:14px; transform:translate(-10px,10px);}
  .vf-corner.br{bottom:14px; right:14px; transform:translate(10px,10px);}
  .vf-corner.tl::before,.vf-corner.tr::before,.vf-corner.bl::before,.vf-corner.br::before{width:100%; height:3px; top:0;}
  .vf-corner.tl::after,.vf-corner.tr::after,.vf-corner.bl::after,.vf-corner.br::after{width:3px; height:100%; left:0;}
  .vf-corner.bl::before,.vf-corner.br::before{top:auto; bottom:0;}
  .vf-corner.tr::after,.vf-corner.br::after{left:auto; right:0;}
  .viewfinder.in-view .vf-corner, .viewfinder:hover .vf-corner{transform:translate(0,0);}

  /* ===== nav ===== */
  header{
    position:fixed; inset:0 0 auto 0; z-index:100;
    padding:18px 0; background:rgba(16,14,28,.55); backdrop-filter:blur(14px);
    border-bottom:1px solid var(--line);
    transition:background .3s ease;
  }
  .nav{display:flex; align-items:center; justify-content:space-between;}
  .brand{display:flex; align-items:center; gap:12px; font-family:var(--ff-display); font-weight:800; font-size:19px;}
  .brand .mark{width:38px; height:38px;}
  .brand .mark svg{width:100%; height:100%; animation:spin 26s linear infinite;}
  @keyframes spin{to{transform:rotate(360deg);}}
  .brand span.ltr{color:var(--accent-2); font-weight:800;}
  nav.links{display:flex; gap:34px; font-size:15px; font-weight:500;}
  nav.links a{position:relative; padding-bottom:4px; opacity:.85; transition:opacity .2s;}
  nav.links a:hover{opacity:1;}
  nav.links a::after{content:""; position:absolute; right:0; bottom:0; width:0; height:2px; background:var(--accent); transition:width .3s;}
  nav.links a:hover::after{width:100%;}
  .cta-btn{
    background:var(--accent); color:var(--ink); font-weight:700; font-size:14.5px;
    padding:11px 22px; border-radius:100px; display:inline-flex; align-items:center; gap:8px;
    box-shadow:0 8px 24px -8px rgba(255,77,46,.6); transition:transform .25s, box-shadow .25s;
    border:none; cursor:pointer;
  }
  .cta-btn:hover{transform:translateY(-2px); box-shadow:0 12px 28px -6px rgba(255,77,46,.75);}
  .cta-btn.ghost{background:transparent; color:var(--paper); border:1px solid var(--line); box-shadow:none;}
  .cta-btn.ghost:hover{border-color:var(--accent); background:rgba(255,77,46,.08);}
  .burger{display:none; width:26px; height:20px; position:relative; cursor:pointer;}
  .burger span{position:absolute; right:0; width:100%; height:2px; background:var(--paper); transition:.3s;}
  .burger span:nth-child(1){top:0;} .burger span:nth-child(2){top:9px;} .burger span:nth-child(3){top:18px;}

  /* ===== hero ===== */
  .hero{
    position:relative; min-height:100svh; display:flex; align-items:flex-end;
    padding-top:120px;
  }
  .hero-bg{position:absolute; inset:0; z-index:0;}
  .hero-bg img{width:100%; height:100%; object-fit:cover; filter:saturate(1.05);}
  .hero-bg::after{
    content:""; position:absolute; inset:0;
    background:
      linear-gradient(0deg, rgba(16,14,28,.98) 6%, rgba(16,14,28,.55) 46%, rgba(16,14,28,.35) 70%),
      linear-gradient(100deg, rgba(16,14,28,.75) 0%, rgba(16,14,28,.15) 55%);
  }
  .hero-content{position:relative; z-index:2; padding-bottom:90px; width:100%;}
  .hero-tag{display:inline-flex; align-items:center; gap:10px; background:rgba(247,242,232,.08); border:1px solid var(--line);
    padding:8px 16px; border-radius:100px; font-size:13.5px; margin-bottom:26px; color:var(--paper);}
  .hero-tag i{width:7px; height:7px; border-radius:50%; background:var(--accent); box-shadow:0 0 0 4px rgba(255,77,46,.25);}
  .hero h1{font-size:clamp(40px,6.6vw,86px); max-width:920px; letter-spacing:-.01em;}
  .hero h1 em{font-style:normal; color:var(--accent);}
  .hero p.lead{margin-top:26px; max-width:520px; font-size:18px; color:var(--text-soft);}
  .hero-actions{display:flex; gap:16px; margin-top:40px; flex-wrap:wrap;}
  .hero-meta{
    display:flex; gap:46px; margin-top:74px; padding-top:28px; border-top:1px solid var(--line); flex-wrap:wrap;
  }
  .hero-meta div b{display:block; font-family:var(--ff-display); font-size:26px; color:var(--accent-2);}
  .hero-meta div span{font-size:13px; color:var(--text-soft);}

  /* marquee strip */
  .marquee{background:var(--accent); color:var(--ink); overflow:hidden; white-space:nowrap; padding:14px 0; position:relative; z-index:3;}
  .marquee-track{display:inline-flex; gap:40px; animation:marquee 32s linear infinite;}
  .marquee-track span{font-family:var(--ff-display); font-weight:800; font-size:15px; letter-spacing:.04em; display:inline-flex; align-items:center; gap:40px;}
  @keyframes marquee{from{transform:translateX(0);} to{transform:translateX(-50%);}}

  /* ===== reveal ===== */
  [data-reveal]{opacity:0; transform:translateY(28px); transition:opacity .8s ease, transform .8s cubic-bezier(.16,.8,.24,1);}
  [data-reveal].in-view{opacity:1; transform:translateY(0);}

  /* ===== intro / philosophy ===== */
  .intro{background:var(--paper); color:var(--ink);}
  .intro .eyebrow{color:#c9481f;}
  .intro .eyebrow::before{background:var(--accent);}
  .intro-grid{display:grid; grid-template-columns:1.1fr .9fr; gap:60px; align-items:center;}
  .intro h2{color:var(--ink); font-size:clamp(28px,3.6vw,44px);}
  .intro p{margin-top:22px; font-size:17.5px; color:#4a4536; max-width:540px;}
  .intro-points{margin-top:34px; display:flex; flex-direction:column; gap:16px;}
  .intro-points li{display:flex; gap:14px; align-items:flex-start; font-size:15.5px; color:#332f22;}
  .intro-points b{font-family:var(--ff-display); color:var(--accent); font-size:18px;}
  .intro-figure{position:relative;}
  .intro-figure .frame{position:relative; border-radius:10px; overflow:hidden; aspect-ratio:4/5;}
  .intro-figure .frame img{width:100%; height:100%; object-fit:cover;}
  .intro-badge{
    position:absolute; bottom:-26px; left:-26px; background:var(--ink); color:var(--paper);
    padding:22px 26px; border-radius:10px; box-shadow:0 20px 40px -14px rgba(0,0,0,.4); max-width:230px;
    border:1px solid var(--line);
  }
  .intro-badge b{display:block; font-family:var(--ff-display); font-size:30px; color:var(--accent-2);}
  .intro-badge span{font-size:13px; color:var(--text-soft);}

  /* ===== corners gallery ===== */
  .corners{background:var(--ink);}
  .corners-head{display:flex; justify-content:space-between; align-items:flex-end; gap:30px; flex-wrap:wrap; margin-bottom:56px;}
  .gallery{display:grid; grid-template-columns:repeat(6,1fr); grid-auto-rows:190px; gap:16px;}
  .g-item{grid-column:span 3; grid-row:span 2; position:relative;}
  .g-item.g-tall{grid-row:span 3;}
  .g-item.g-wide{grid-column:span 4;}
  .g-item.g-narrow{grid-column:span 2;}
  .g-item img{width:100%; height:100%; object-fit:cover; transition:transform 1.1s cubic-bezier(.16,.8,.24,1);}
  .g-item:hover img{transform:scale(1.06);}
  .g-cap{
    position:absolute; z-index:2; bottom:16px; right:16px; left:16px; display:flex; justify-content:space-between; align-items:flex-end;
  }
  .g-cap b{font-family:var(--ff-display); font-size:15px; background:rgba(16,14,28,.65); backdrop-filter:blur(6px); padding:7px 14px; border-radius:100px; border:1px solid var(--line);}
  .g-item::after{content:""; position:absolute; inset:0; background:linear-gradient(0deg, rgba(16,14,28,.55) 0%, rgba(16,14,28,0) 42%); z-index:1;}

  /* ===== services ===== */
  .services{background:var(--ink-2); position:relative;}
  .svc-grid{display:grid; grid-template-columns:repeat(4,1fr); gap:1px; background:var(--line); border:1px solid var(--line); border-radius:14px; overflow:hidden; margin-top:56px;}
  .svc-card{background:var(--ink-2); padding:38px 30px; transition:background .3s;}
  .svc-card:hover{background:var(--ink-3);}
  .svc-num{font-family:var(--ff-display); font-size:13px; color:var(--accent-2); letter-spacing:.1em; margin-bottom:24px; display:block;}
  .svc-card svg{width:34px; height:34px; stroke:var(--accent); margin-bottom:22px;}
  .svc-card h3{font-size:20px; margin-bottom:12px;}
  .svc-card p{font-size:14.5px; color:var(--text-soft); margin-bottom:18px;}
  .svc-card ul li{font-size:13.5px; color:var(--text-soft); padding:5px 0 5px 0; border-top:1px solid var(--line); display:flex; align-items:center; gap:8px;}
  .svc-card ul li:first-child{border-top:none;}
  .svc-card ul li::before{content:""; width:4px; height:4px; border-radius:50%; background:var(--accent);}

  /* ===== process ===== */
  .process{background:var(--paper); color:var(--ink);}
  .process .eyebrow{color:#c9481f;} .process .eyebrow::before{background:var(--accent);}
  .process h2{color:var(--ink);}
  .proc-row{display:grid; grid-template-columns:repeat(4,1fr); gap:0; margin-top:64px; position:relative;}
  .proc-row::before{content:""; position:absolute; top:26px; left:0; right:0; height:1px; background:var(--line-dark);}
  .proc-step{padding-right:0; position:relative; padding-top:0;}
  .proc-num{
    width:52px; height:52px; border-radius:50%; background:var(--ink); color:var(--accent-2);
    font-family:var(--ff-display); font-weight:800; font-size:19px; display:flex; align-items:center; justify-content:center;
    margin-bottom:26px; position:relative; z-index:1;
  }
  .proc-step h3{font-size:18px; color:var(--ink); margin-bottom:10px;}
  .proc-step p{font-size:14.5px; color:#5a5544; max-width:230px;}
  .proc-step:not(:last-child){padding-left:26px;}

  /* ===== pricing ===== */
  .pricing{background:var(--ink);}
  .price-toggle{display:inline-flex; background:var(--ink-2); border:1px solid var(--line); border-radius:100px; padding:5px; margin-top:10px;}
  .price-toggle button{
    border:none; background:transparent; color:var(--text-soft); font-family:var(--ff-body); font-weight:700; font-size:14.5px;
    padding:11px 26px; border-radius:100px; cursor:pointer; transition:.3s;
  }
  .price-toggle button.active{background:var(--accent); color:var(--ink);}
  .price-panels{margin-top:52px;}
  .price-grid{display:none; grid-template-columns:repeat(3,1fr); gap:24px;}
  .price-grid.active{display:grid;}
  .price-card{
    background:var(--ink-2); border:1px solid var(--line); border-radius:16px; padding:36px 30px; position:relative; display:flex; flex-direction:column;
    transition:transform .3s, border-color .3s;
  }
  .price-card:hover{transform:translateY(-6px); border-color:rgba(255,77,46,.5);}
  .price-card.featured{border-color:var(--accent); background:linear-gradient(160deg, var(--ink-3), var(--ink-2));}
  .price-flag{position:absolute; top:-13px; right:26px; background:var(--accent); color:var(--ink); font-size:12px; font-weight:800; padding:5px 14px; border-radius:100px;}
  .price-card h3{font-size:21px; margin-bottom:6px;}
  .price-card .p-desc{font-size:13.5px; color:var(--text-soft); margin-bottom:22px; min-height:38px;}
  .price-card .p-value{font-family:var(--ff-display); font-size:38px; color:var(--accent-2); margin-bottom:4px;}
  .price-card .p-value sup{font-size:14px; color:var(--text-soft); font-weight:400;}
  .price-card .p-note{font-size:12.5px; color:var(--text-soft); margin-bottom:26px;}
  .price-card ul{margin-bottom:28px; flex-grow:1;}
  .price-card ul li{font-size:14px; padding:8px 0; border-top:1px solid var(--line); display:flex; gap:10px; align-items:flex-start;}
  .price-card ul li:first-child{border-top:none;}
  .price-card ul li svg{width:15px; height:15px; stroke:var(--accent-2); flex-shrink:0; margin-top:3px;}
  .price-foot{margin-top:40px; font-size:13.5px; color:var(--text-soft); text-align:center;}

  /* ===== who / marquee tags ===== */
  .who{background:var(--ink-2);}
  .tag-cloud{display:flex; flex-wrap:wrap; gap:14px; margin-top:50px;}
  .tag-cloud span{
    border:1px solid var(--line); padding:12px 24px; border-radius:100px; font-size:15px; color:var(--text-soft);
    transition:.25s; cursor:default;
  }
  .tag-cloud span:hover{border-color:var(--accent); color:var(--paper); background:rgba(255,77,46,.08);}

  /* ===== CTA band ===== */
  .cta-band{
    background:var(--ink); position:relative; padding:130px 0; text-align:center; overflow:hidden;
  }
  .cta-band .mark-bg{position:absolute; top:50%; left:50%; width:900px; height:900px; transform:translate(-50%,-50%); opacity:.05;}
  .cta-band .mark-bg svg{width:100%; height:100%; animation:spin 60s linear infinite;}
  .cta-band h2{font-size:clamp(34px,5.2vw,66px); max-width:820px; margin:0 auto; position:relative; z-index:1;}
  .cta-band h2 em{font-style:normal; color:var(--accent);}
  .cta-band p{margin:24px auto 0; color:var(--text-soft); font-size:17px; max-width:480px; position:relative; z-index:1;}
  .cta-band .hero-actions{justify-content:center; position:relative; z-index:1;}

  /* ===== footer ===== */
  footer{background:var(--paper); color:var(--ink); padding:72px 0 30px;}
  .foot-grid{display:grid; grid-template-columns:1.4fr 1fr 1fr 1fr; gap:40px; padding-bottom:50px; border-bottom:1px solid var(--line-dark);}
  .foot-brand .brand{color:var(--ink);}
  .foot-brand p{margin-top:18px; font-size:14.5px; color:#5a5544; max-width:280px;}
  .foot-col h4{font-family:var(--ff-display); font-size:15px; margin-bottom:20px;}
  .foot-col ul li{margin-bottom:12px; font-size:14.5px; color:#4a4536;}
  .foot-col ul li a:hover{color:var(--accent);}
  .foot-social{display:flex; gap:10px; margin-top:18px;}
  .foot-social a{width:38px; height:38px; border-radius:50%; border:1px solid var(--line-dark); display:flex; align-items:center; justify-content:center; transition:.25s;}
  .foot-social a:hover{background:var(--accent); border-color:var(--accent); color:var(--paper);}
  .foot-social svg{width:16px; height:16px;}
  .foot-bottom{display:flex; justify-content:space-between; padding-top:26px; font-size:13px; color:#8a8368; flex-wrap:wrap; gap:12px;}

  @media (max-width:980px){
    nav.links, header .cta-btn{display:none;}
    .burger{display:block;}
    .intro-grid{grid-template-columns:1fr;}
    .intro-figure{order:-1;}
    .svc-grid{grid-template-columns:repeat(2,1fr);}
    .proc-row{grid-template-columns:repeat(2,1fr); row-gap:50px;}
    .proc-row::before{display:none;}
    .price-grid{grid-template-columns:1fr !important;}
    .foot-grid{grid-template-columns:1fr 1fr; row-gap:36px;}
    .gallery{grid-template-columns:repeat(2,1fr); grid-auto-rows:220px;}
    .g-item, .g-item.g-wide, .g-item.g-narrow{grid-column:span 2 !important;}
  }
  @media (max-width:560px){
    .section{padding:80px 0;}
    .hero-meta{gap:28px;}
    .svc-grid{grid-template-columns:1fr;}
    .foot-grid{grid-template-columns:1fr;}
  }
  @media (prefers-reduced-motion:reduce){
    *{animation-duration:.001ms !important; transition-duration:.001ms !important;}
  }
</style>
</head>
